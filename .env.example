# 타이브레이커 환경변수 예시
# 이 파일을 .env.local로 복사한 뒤 실제 값을 채우세요.
#   cp .env.example .env.local  (Mac/Linux)
#   Copy-Item .env.example .env.local  (PowerShell)
# .env.local은 .gitignore에 포함되어 GitHub에 절대 올라가지 않습니다.

# ─── Supabase ───────────────────────────────────────────────
# Supabase 대시보드 → Settings → API
# (2025년 후반 키 명명 변경: anon → Publishable, service_role → Secret)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# Publishable key — 클라이언트에서 사용 (sb_publishable_... 또는 eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# Secret key — 서버 전용, 절대 클라이언트 코드에서 import 금지 (sb_secret_... 또는 eyJ...)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ─── Anthropic Claude ───────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google OAuth ───────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
# 이 두 개는 Supabase 대시보드의 Authentication → Providers → Google 에 입력
# (Next.js 코드에는 직접 안 씀. Supabase가 처리.)
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ─── 앱 설정 ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# 일일 분석 횟수 제한 (DECISIONS.md 참조)
DAILY_ANALYSIS_LIMIT=20
